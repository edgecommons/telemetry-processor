{
  "logging": {
    "level": "INFO",
    "rust_format": "{timestamp} [{level}] [{component}] {target} - {message}"
  },
  "heartbeat": {
    "intervalSecs": 10,
    "measures": {
      "cpu": true,
      "memory": true
    }
  },
  "metricEmission": {
    "target": "messaging",
    "namespace": "edgecommons"
  },
  "streaming": {
    "streams": [
      {
        "name": "archive",
        "sink": {
          "type": "file",
          "format": "parquet",
          "mode": "rows",
          "dir": "./out/archive",
          "partitionBy": "dt={yyyy-MM-dd}/hr={HH}",
          "maxFileBytes": 1048576,
          "maxFiles": 16,
          "rollEverySecs": 30,
          "onFull": "dropOldest",
          "compression": "snappy"
        },
        "buffer": {
          "path": "./out/stream-archive",
          "segmentBytes": 1048576,
          "maxDiskBytes": 67108864,
          "onFull": "dropOldest"
        },
        "batch": {
          "maxRecords": 500,
          "maxBytes": 1048576,
          "maxLatencyMs": 2000
        },
        "delivery": {
          "pollIntervalMs": 500
        }
      }
    ]
  },
  "tags": {
    "appId": "Demo",
    "site": "factory-1",
    "shop": "shopA",
    "line": "line1"
  },
  "component": {
    "global": {
      "defaults": {
        "key": "body.signal.id"
      }
    },
    "instances": [
      {
        "id": "downsample-local",
        "subscribe": [
          "ecv1/+/+/+/data/#"
        ],
        "pipeline": [
          {
            "filter": {
              "quality": "GOOD"
            }
          },
          {
            "sample": {
              "everyMs": 1000,
              "by": "body.signal.id"
            }
          }
        ],
        "target": "local",
        "publish": {
          "topic": "ecv1/{ThingName}/telemetry-processor/data/downsampled"
        }
      },
      {
        "id": "archive",
        "subscribe": [
          "ecv1/+/+/+/data/#"
        ],
        "pipeline": [
          {
            "filter": {
              "quality": "GOOD"
            }
          },
          {
            "aggregate": {
              "window": "5s",
              "by": "body.signal.id",
              "fn": [
                "avg",
                "max",
                "min",
                "count",
                "last"
              ]
            }
          }
        ],
        "target": "stream:archive",
        "publish": {
          "partitionKey": "body.signal.id"
        }
      }
    ],
    "token": "telemetry-processor"
  }
}